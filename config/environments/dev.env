# ============================================================
# TravelHub — Ambiente: DEV
# ============================================================
# Uso: source config/environments/dev.env && bash deploy-all.sh
# ============================================================
export ENV="dev"
export GCP_PROJECT_ID="gen-lang-client-0930444414"
export GCP_REGION="us-central1"
export DOMAIN="apitravelhub.site"

# Naming
export PREFIX="${ENV}-travelhub"
export VPC_NAME="${PREFIX}-vpc"
export CLOUD_ARMOR_POLICY="${PREFIX}-security-policy"
export DB_INSTANCE_NAME="${PREFIX}-db"
export DB_NAME="travelhub"
export DB_USER="travelhub_app"

# API Gateway
export API_GATEWAY_ID="${PREFIX}-api"
export API_GATEWAY_NAME="${PREFIX}-gateway"

# Load Balancer
export LB_IP_NAME="${PREFIX}-lb-ip"
export LB_NEG_NAME="${PREFIX}-gateway-neg"
export LB_BACKEND_NAME="${PREFIX}-backend-service"
export LB_URL_MAP_NAME="${PREFIX}-url-map"
export LB_CERT_NAME="${PREFIX}-ssl-cert"
export LB_PROXY_NAME="${PREFIX}-https-proxy"
export LB_FWD_RULE_NAME="${PREFIX}-forwarding-rule"

# SSL
export SSL_MODE="self-signed"

# Networking
export SUBNET_PUBLIC_NAME="${PREFIX}-subnet-public"
export SUBNET_SERVICES_NAME="${PREFIX}-subnet-services"
export SUBNET_DATA_NAME="${PREFIX}-subnet-data"
export VPC_CONNECTOR_NAME="${PREFIX}-connector"
export PRIVATE_RANGE_NAME="${PREFIX}-private-range"

export SUBNET_PUBLIC_CIDR="10.10.1.0/24"
export SUBNET_SERVICES_CIDR="10.10.2.0/24"
export SUBNET_DATA_CIDR="10.10.3.0/24"
export VPC_CONNECTOR_CIDR="10.10.8.0/28"
export PRIVATE_RANGE_CIDR="10.100.0.0"
export PRIVATE_RANGE_PREFIX="20"

# Cloud SQL
export DB_TIER="db-f1-micro"
export DB_HA="zonal"        # zonal para dev, regional para prod
export DB_BACKUP="false"    # false para dev, true para prod
export DB_STORAGE="10GB"

# Kafka VM (Compute Engine — broker self-managed en subnet-data)
export KAFKA_VM_NAME="${PREFIX}-kafka"
export KAFKA_VM_ZONE="${GCP_REGION}-c"
export KAFKA_VM_MACHINE_TYPE="e2-small"
export KAFKA_VM_DISK_SIZE="20GB"
export KAFKA_VM_DISK_TYPE="pd-balanced"
export KAFKA_VM_IMAGE_FAMILY="ubuntu-2204-lts"
export KAFKA_VM_IMAGE_PROJECT="ubuntu-os-cloud"

# Cloud Armor
export CLOUD_ARMOR_ENABLED="true"
export ARMOR_WAF_ENABLED="true"
export ARMOR_GEO_BLOCK_ENABLED="true"
export RATE_LIMIT_GLOBAL="100"
export RATE_LIMIT_LOGIN="10"
export RATE_LIMIT_PAYMENTS="20"

# Gateway
# Se completa despues del deploy de user-services
export JWKS_URI=""

# Microservicios Cloud Run (URLs se llenan post-deploy de cada servicio)
export USER_SERVICES_URL="https://user-services-ridyy4wz4q-uc.a.run.app"
export SEARCH_SERVICES_URL="https://dev-search-service-app-service-ridyy4wz4q-uc.a.run.app"
export BOOKING_SERVICES_URL="https://dev-booking-service-app-service-ridyy4wz4q-uc.a.run.app"
export PAYMENTS_SERVICES_URL=""
export INVENTORY_SERVICES_URL=""
export NOTIFICATION_SERVICES_URL=""
export PMS_SERVICES_URL="https://pms-integration-services-ridyy4wz4q-uc.a.run.app"
export CART_SERVICES_URL=""
